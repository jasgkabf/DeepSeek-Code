<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_medium">

        <androidx.cardview.widget.CardView
            android:id="@+id/permissionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardBackgroundColor="@color/warning"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_warning"
                        android:tint="@color/surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/permission_required"
                        android:textColor="@color/surface"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/permissionMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:textColor="@color/surface"
                    android:textSize="@dimen/text_size_body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermission"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:text="@string/go_to_settings"
                    android:textColor="@color/primary"
                    app:backgroundTint="@color/surface" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/speedCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintTop_toBottomOf="@id/permissionCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/click_speed_label"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="选择点击间隔时间"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_caption" />

                <RadioGroup
                    android:id="@+id/speedGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/speedFast"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/speed_button_height"
                        android:layout_weight="1"
                        android:background="@drawable/speed_button_background"
                        android:button="@null"
                        android:gravity="center"
                        android:text="@string/speed_fast"
                        android:textColor="@color/text_selector"
                        android:textSize="@dimen/text_size_body" />

                    <RadioButton
                        android:id="@+id/speedNormal"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/speed_button_height"
                        android:layout_marginStart="@dimen/margin_small"
                        android:layout_weight="1"
                        android:background="@drawable/speed_button_background"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:text="@string/speed_normal"
                        android:textColor="@color/text_selector"
                        android:textSize="@dimen/text_size_body" />

                    <RadioButton
                        android:id="@+id/speedSlow"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/speed_button_height"
                        android:layout_marginStart="@dimen/margin_small"
                        android:layout_weight="1"
                        android:background="@drawable/speed_button_background"
                        android:button="@null"
                        android:gravity="center"
                        android:text="@string/speed_slow"
                        android:textColor="@color/text_selector"
                        android:textSize="@dimen/text_size_body" />

                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_small"
                    android:text="快速: 100ms | 正常: 300ms | 慢速: 500ms"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_caption" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/countCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintTop_toBottomOf="@id/speedCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/click_count_label"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/countInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/hint_click_count"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusBottomEnd="@dimen/button_corner_radius"
                        app:boxCornerRadiusBottomStart="@dimen/button_corner_radius"
                        app:boxCornerRadiusTopEnd="@dimen/button_corner_radius"
                        app:boxCornerRadiusTopStart="@dimen/button_corner_radius">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/countInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="100" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/infiniteSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_small"
                        android:text="@string/click_count_infinite"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_body" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartFloating"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/margin_large"
            android:text="@string/start_floating_button"
            android:textSize="@dimen/text_size_subtitle"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/button_corner_radius"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:layout_constraintTop_toBottomOf="@id/countCard" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:text="点击启动后，悬浮按钮将显示在屏幕上"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnStartFloating" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
