{
  "name": "deepseek-code",
  "version": "1.0.0",
  "description": "DeepSeek Code - 命令行 AI 编程助手",
  "main": "dist/index.js",
  "bin": {
    "deepseek-code": "dist/index.js",
    "DeepSeek-Code": "dist/index.js",
    "DEEPSEEK-CODE": "dist/index.js",
    "ds-code": "dist/index.js",
    "DS-Code": "dist/index.js",
    "dscode": "dist/index.js",
    "DSCode": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc && npm link",
    "build:only": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "ts-node src/__tests__/safety.test.ts && ts-node src/__tests__/crypto.test.ts && ts-node src/__tests__/session.test.ts && ts-node src/__tests__/env.test.ts",
    "uninstall": "node -e \"const {performUninstall}=require('./dist/uninstall');const{setLanguage}=require('./dist/i18n');setLanguage('zh');performUninstall(true).then(r=>{console.log(r.message);if(r.success)process.exit(0);else process.exit(1);})\""
  },
  "keywords": ["ai", "cli", "coding-assistant", "deepseek"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
